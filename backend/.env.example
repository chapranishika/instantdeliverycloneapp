# ══════════════════════════════════════════════════════════════════════════════
# Zepto Clone — Environment Variables
# cp .env.example .env  then fill in your password
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase PostgreSQL — zepto-clone project (lqvldpojrcokvfmlfuhe) ──────────
# Project URL: https://lqvldpojrcokvfmlfuhe.supabase.co
# Region: ap-south-1 | Tables in: public schema

# FOR RUNNING THE APP — Transaction Pooler (port 6543, pgBouncer):
DATABASE_URL=postgresql+asyncpg://postgres.lqvldpojrcokvfmlfuhe:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# FOR MIGRATIONS + SEED — Direct connection (port 5432):
# DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.lqvldpojrcokvfmlfuhe.supabase.co:5432/postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Upstash (free serverless Redis):
# REDIS_URL=rediss://:[password]@[host].upstash.io:6379

# ── Anthropic API (Gopi Bahu assistant) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
